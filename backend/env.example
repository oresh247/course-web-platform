# OpenAI API Configuration
OPENAI_API_KEY=your_openai_api_key_here

# OpenRouter (https://openrouter.ai/) — при заданном OPENROUTER_API_KEY все вызовы идут через OpenRouter.
# Для генерации большой структуры IT-курса (в т.ч. про AI-сервисы) рекомендуется:
# OPENROUTER_API_KEY=your_openrouter_key
# OPENAI_MODEL_DEFAULT=openai/gpt-4o
# или anthropic/claude-sonnet-4, google/gemini-2.0-flash — хороший JSON и длинный контекст.
# OPENAI_MAX_TOKENS_COURSE_STRUCTURE=8000

# Optional defaults
OPENAI_MODEL_DEFAULT=gpt-4
OPENAI_MODEL_DETAILED_CONTENT=gpt-4-turbo-preview
OPENAI_TIMEOUT=120
OPENAI_TEMPERATURE_DEFAULT=0.7
OPENAI_MAX_TOKENS_DEFAULT=3000
# Генерация структуры курса: нужен запас токенов (иначе JSON обрезается и парсинг падает). Рекомендуется 8000+.
OPENAI_MAX_TOKENS_COURSE_STRUCTURE=8000
OPENAI_MAX_TOKENS_MODULE_CONTENT=4096
OPENAI_MAX_TOKENS_LESSON_DETAILED=4000
OPENAI_MAX_TOKENS_TOPIC_MATERIAL=4096
OPENAI_MAX_TOKENS_SHORT_MIN=200
OPENAI_MAX_TOKENS_SHORT_MAX=500
OPENAI_RETRIES_DEFAULT=2
OPENAI_BACKOFF_SECONDS_DEFAULT=1.0

# Proxy Settings (optional, для корпоративных сетей)
# Раскомментируйте и настройте, если используете прокси
# HTTP_PROXY=http://your-proxy:port
# HTTPS_PROXY=http://your-proxy:port

# HeyGen API (optional, для генерации видео)
# Если ключ не указан, будет использован мок-сервис
HEYGEN_API_KEY=
HEYGEN_API_URL=https://api.heygen.com
HEYGEN_DEFAULT_AVATAR_ID=Abigail_expressive_2024112501
# Для озвучки на русском выберите голос с поддержкой Russian (иначе HeyGen вернёт VOICE_CLIENT_ERROR).
# Список голосов: GET https://api.heygen.com/v2/voices (заголовок X-Api-Key), в ответе ищите voice_id с language "Russian".
HEYGEN_DEFAULT_VOICE_ID=9799f1ba6acd4b2b993fe813a18f9a91
HEYGEN_TIMEOUT=30
HEYGEN_STATUS_TIMEOUT=10
HEYGEN_DOWNLOAD_TIMEOUT=60
HEYGEN_POLL_INTERVAL_SECONDS=10

# Database
# Для локальной разработки с SQLite (если DATABASE_URL не указан):
DATABASE_PATH=courses.db

# Для подключения к PostgreSQL на Render (приоритет над DATABASE_PATH):
# DATABASE_URL=postgresql://user:password@host:port/dbname

# Server Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=True

# Production Settings (для Render.com)
PYTHONUNBUFFERED=1
ALLOWED_ORIGINS=*

